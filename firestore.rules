rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.current_role;
    }

    function isHighCommand() {
      let role = getUserRole();
      return role == 'director' || role == 'sub_director';
    }

    function isMidCommand() {
      let role = getUserRole();
      return role == 'battalion_commander' || role == 'company_commander';
    }

    function isOperationalCommand() {
      let role = getUserRole();
      return role == 'school_chief' || role == 'control_chief' ||
             role == 'week_officer' || role == 'guard_officer' ||
             role == 'kitchen_officer';
    }

    function isGateOperator() {
      let role = getUserRole();
      return role == 'guard_brigadier' || role == 'guard_sub_brigadier' ||
             role == 'guard_cadet' || role == 'prevention_device';
    }

    function canScanAccess() {
      return isGateOperator() || getUserRole() == 'guard_officer' ||
             getUserRole() == 'school_chief' || getUserRole() == 'week_officer';
    }

    // ── Users ─────────────────────────────────────────────
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer perfiles
      allow read: if isAuthenticated();
      // Solo el propio usuario puede crear su perfil (registro)
      allow create: if isOwner(userId);
      // El propio usuario puede actualizar ciertos campos
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['current_role', 'base_role', 'role_assigned_at', 'role_assigned_by_uid', 'is_active']);
      // Director/Subdirector pueden actualizar roles y estado
      allow update: if isHighCommand();
      // Nadie puede eliminar usuarios
      allow delete: if false;
    }

    // ── Access Logs ───────────────────────────────────────
    match /access_logs/{logId} {
      // Lectura: personal con panel operativo o de mando
      allow read: if isAuthenticated() &&
        (isHighCommand() || isMidCommand() || isOperationalCommand() || isGateOperator());
      // Escritura: solo operadores de garita y roles con permiso de escaneo
      allow create: if isAuthenticated() && canScanAccess();
      // Logs son inmutables
      allow update, delete: if false;
    }

    // ── Alerts ────────────────────────────────────────────
    match /alerts/{alertId} {
      // Lectura: todos los autenticados
      allow read: if isAuthenticated();
      // Creación: operadores y mandos
      allow create: if isAuthenticated() &&
        (isHighCommand() || isMidCommand() || isOperationalCommand() || isGateOperator());
      // Actualización (marcar leída): cualquier autenticado
      allow update: if isAuthenticated();
      // Eliminación: solo Director/Subdirector
      allow delete: if isHighCommand();
    }

    // ── Vehicles ──────────────────────────────────────────
    match /vehicles/{vehicleId} {
      // Lectura: todos los autenticados
      allow read: if isAuthenticated();
      // Creación: cualquier autenticado puede registrar un vehículo
      allow create: if isAuthenticated();
      // Actualización: Director/Subdirector (aprobar/rechazar/bloquear)
      allow update: if isHighCommand();
      // Eliminación: solo Director
      allow delete: if getUserRole() == 'director';
    }

    // ── Audit Logs ────────────────────────────────────────
    match /audit_logs/{logId} {
      // Lectura: solo Director/Subdirector
      allow read: if isHighCommand();
      // Creación: cualquier autenticado (el sistema registra auditoría)
      allow create: if isAuthenticated();
      // Inmutables
      allow update, delete: if false;
    }

    // ── Guard Shifts ──────────────────────────────────────
    match /guard_shifts/{shiftId} {
      allow read: if isAuthenticated() &&
        (isHighCommand() || isOperationalCommand() || isGateOperator());
      allow create: if isAuthenticated() &&
        (getUserRole() == 'guard_officer' || isHighCommand());
      allow update: if isAuthenticated() &&
        (getUserRole() == 'guard_officer' || isHighCommand());
      allow delete: if false;
    }

    // ── Bitacora ──────────────────────────────────────────
    match /bitacora/{entryId} {
      allow read: if isAuthenticated() &&
        (isHighCommand() || isOperationalCommand());
      allow create: if isAuthenticated() &&
        (getUserRole() == 'guard_officer' || getUserRole() == 'school_chief' ||
         getUserRole() == 'week_officer');
      allow update: if isHighCommand();
      allow delete: if false;
    }

    // ── Metadata ──────────────────────────────────────────
    match /metadata/{docId} {
      allow read: if isAuthenticated();
      allow write: if isHighCommand();
    }
  }
}